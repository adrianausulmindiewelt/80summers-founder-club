# Jung und Hungrig — Digital-Reality-Check Funnel
# Kopiere diese Datei nach .env (oder konfiguriere die Variablen direkt in Vercel
# unter Settings → Environment Variables).
#
# Ohne diese Keys läuft der Funnel im Mock-Modus: Plan + Avatare werden
# clientseitig erzeugt, Stripe leitet auf die Mock-Up-Sell-Seite weiter, Brevo-
# Calls sind no-ops. So kannst du den End-to-End-Flow auch ohne externe Accounts
# klicken.

# ─── Anthropic (Plan-Generierung) ─────────────────────────
ANTHROPIC_API_KEY=
# Default: claude-sonnet-4-6. Setze claude-opus-4-7 für höchste Qualität.
ANTHROPIC_PLAN_MODEL=claude-sonnet-4-6

# ─── Avatar-Generator ────────────────────────────────────
# Provider: 'replicate' (default) oder 'fal'
AVATAR_PROVIDER=replicate
REPLICATE_API_TOKEN=
# Optional: gepinnter Modell-Hash für InstantID
REPLICATE_INSTANTID_MODEL=lucataco/sdxl-instantid:af5ddc...
FAL_KEY=

# ─── Supabase (optional) ──────────────────────────────────
# Wenn nicht gesetzt: localStorage ist die einzige Persistenz.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ─── Brevo (Email-Sequenz) ────────────────────────────────
BREVO_API_KEY=
BREVO_MA_KEY=
# Liste, in die alle Funnel-Leads landen (Brevo → Listen-ID)
BREVO_LIST_ID=
# Optional: Template-ID für die Auslieferungs-Email nach Kauf
BREVO_DELIVERY_TEMPLATE_ID=

# ─── Stripe ───────────────────────────────────────────────
STRIPE_SECRET_KEY=
# Webhook signing secret aus Stripe Dashboard → Webhooks → ... → Signing secret
STRIPE_WEBHOOK_SECRET=
# Optional: vorkonfigurierter Subscription-Price (49€/Monat)
STRIPE_UPSELL_PRICE_ID=
# Optional: Coupon für 20€ off im ersten Monat
STRIPE_UPSELL_COUPON_ID=

# ─── Allgemein ────────────────────────────────────────────
# Wird für success_url / cancel_url von Stripe verwendet
PUBLIC_ORIGIN=https://jung-und-hungrig.com
